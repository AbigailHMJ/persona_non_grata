{% extends 'base.html.twig' %}

{% block title %}Genres{% endblock %}

{% block body %}
{% if app.user %}
<main>
    <h1>Genres</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>{{ genre.id }}</th>
                <td>{{ genre.keyword }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_genres_index') }}">Revenir à la liste</a>

    <a href="{{ path('app_genres_edit', {'id': genre.id}) }}">Modifier</a>

    {{ include('genres/_delete_form.html.twig') }}
    </main>
    {% endif %}
{% endblock %}
