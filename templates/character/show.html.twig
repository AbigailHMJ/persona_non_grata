{% extends 'base.html.twig' %}

{% block title %}Character{% endblock %}

{% block body %}
    <h1>Character</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ character.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ character.name }}</td>
            </tr>
            <tr>
                <th>Age</th>
                <td>{{ character.age }}</td>
            </tr>
            <tr>
                <th>Physical_traits</th>
                <td>{{ character.physicalTraits }}</td>
            </tr>
            <tr>
                <th>Character_traits</th>
                <td>{{ character.characterTraits }}</td>
            </tr>
            <tr>
                <th>Background</th>
                <td>{{ character.background }}</td>
            </tr>
            <tr>
                <th>Others</th>
                <td>{{ character.others }}</td>
            </tr>
            <tr>
                <th>Illustration</th>
                <td>{{ character.illustration }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_character_index') }}">back to list</a>

    <a href="{{ path('app_character_edit', {'id': character.id}) }}">edit</a>

    {{ include('character/_delete_form.html.twig') }}
{% endblock %}
