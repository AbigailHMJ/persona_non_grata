{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
<main>
<form action="{{ path('app_login') }}" method="POST">
    {% if error %}
        <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
    {% endif %}

    <h1>Se connecter</h1>
    <div class="login"><label class="login-label" for="inputUsername">Nom d'utilisateur : </label>
    <input class="login-input" type="text" value="{{ last_username }}" name="username" id="inputUsername" class="form-control" autocomplete="username" required autofocus>
    <label class="login-label" for="inputPassword">Mot de passe : </label>
    <input type="password" name="password" id="inputPassword" class="form-control; login-input" autocomplete="current-password" required>
    <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

    <div class="checkbox mb-3">
        <label>
            <input type="checkbox" name="_remember_me"> Rester connecté.e ?
        </label>
    </div>

    <button class="btn" type="submit">
        Connexion
    </button>
    </div>
</form>
</main>
{% endblock %}
