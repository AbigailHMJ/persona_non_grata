{% extends 'base.html.twig' %}

{% block title %}Voir le profil
{% endblock %}

{% block body %}
	{% if app.user %}
		<h1></h1>


		<table class="table">
			<tbody>
				{# <tr>
				                <th>Id</th>
				                <td>{{ user.id }}</td>
				            </tr> #}
				<tr>
					<th>Username</th>
					<td>{{ user.username }}</td>
				</tr>
				<tr>
					<th>Email</th>
					<td>{{ user.email }}</td>
				</tr>
				<tr>
					<th>Birthdate</th>
					<td>{{ user.birthdate ? user.birthdate|date('d-m-Y') : '' }}</td>
				</tr>
			</tbody>
		</table>

		<a href="{{ path('app_user_index') }}">Liste des membres</a>

		<a href="{{ path('app_user_edit', {'id': user.id}) }}">Modifier</a>

		{% if is_granted('ROLE_ADMIN') %}
			{{ include('user/_delete_form.html.twig') }}
		{% endif %}
	{% endif %}
{% endblock %}
