{% extends 'base.html.twig' %}

{% block title %}Addons index{% endblock %}

{% block body %}
    <h1>Addons index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Playlist</th>
                <th>Moodboard</th>
                <th>Other</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for addon in addons %}
            <tr>
                <td>{{ addon.id }}</td>
                <td>{{ addon.playlist }}</td>
                <td>{{ addon.moodboard }}</td>
                <td>{{ addon.other }}</td>
                <td>
                    <a href="{{ path('app_addons_show', {'id': addon.id}) }}">show</a>
                    <a href="{{ path('app_addons_edit', {'id': addon.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_addons_new') }}">Create new</a>
{% endblock %}
