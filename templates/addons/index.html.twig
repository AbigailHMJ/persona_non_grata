{% extends 'base.html.twig' %}

{% block title %}Index des add-ons{% endblock %}

{% block body %}
{% if app.user %}
<main>
    <h1>Index des add-ons</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Playlist</th>
                <th>Moodboard</th>
                <th>Other</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for addon in addons %}
            <tr>
                <td>{{ addon.id }}</td>
                <td>{{ addon.playlist }}</td>
                <td>{{ addon.moodboard }}</td>
                <td>{{ addon.other }}</td>
                <td>
                    <a href="{{ path('app_addons_show', {'id': addon.id}) }}">Voir</a>
                    <a href="{{ path('app_addons_edit', {'id': addon.id}) }}">Modifier</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">Aucun add-on trouvé</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_addons_new') }}">Ajouter</a>
    </main>
    {% endif %}
{% endblock %}