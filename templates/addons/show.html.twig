{% extends 'base.html.twig' %}

{% block title %}Add-ons{% endblock %}

{% block body %}
{% if app.user %}
<main>
    <h1>Add-ons</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ addon.id }}</td>
            </tr>
            <tr>
                <th>Playlist</th>
                <td>{{ addon.playlist }}</td>
            </tr>
            <tr>
                <th>Moodboard</th>
                <td>{{ addon.moodboard }}</td>
            </tr>
            <tr>
                <th>Other</th>
                <td>{{ addon.other }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_addons_index') }}">Revenir à la liste</a>

    <a href="{{ path('app_addons_edit', {'id': addon.id}) }}">Modifier</a>

    {{ include('addons/_delete_form.html.twig') }}
    </main>
    {% endif %}
{% endblock %}
